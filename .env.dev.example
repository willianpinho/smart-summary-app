# Smart Summary App — Development Environment Variables
# Copy to .env and fill in real values

# Backend
OPENAI_API_KEY=sk-your-api-key-here
ALLOWED_ORIGINS=https://app.smartsummary.dev.willianpinho.com

# Frontend (baked into image at build time)
NEXT_PUBLIC_API_URL=https://api.smartsummary.dev.willianpinho.com

# Database (shared PostgreSQL — optional, for future use)
DATABASE_URL=postgresql://smartsummary:changeme@shared-postgres:5432/smartsummary

# Redis (shared Redis — optional, for future use)
REDIS_URL=redis://shared-redis:6379/2
